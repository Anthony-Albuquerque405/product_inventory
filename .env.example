# ============================================================
# VARIÁVEIS DE AMBIENTE - EXEMPLO
# ============================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NÃO compartilhe o arquivo .env — ele está no .gitignore.
#
#   cp .env.example .env
# ============================================================

# --- Supabase ---
# URL do projeto (encontrada em: Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co

# Chave anônima pública (encontrada em: Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
